ascend info tasks
# CHECK-LABEL: ascend info tasks
# CHECK-NEXT:  Device Stream Task Invocation
# CHECK-NEXT:* {{[0-9]+}} {{[0-9]+}} {{[0-9]+}} {{[0-9a-zA-Z_]+}}

ascend info stream
# CHECK-LABEL: ascend info stream
