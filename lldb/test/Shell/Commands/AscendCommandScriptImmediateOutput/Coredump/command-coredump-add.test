# REQUIRES: ascend-debugger
# RUN: cd ~/coredump_file
# RUN: msdebug --core AddCustom.core -s %s | FileCheck %s -dump-input=always

ascend info summary
# CHECK-LABEL: ascend info summary
# CHECK:  CoreId  CoreType  DeviceId  ChipType
# CHECK-NEXT:*  36       AIV       0        A2/A3
# CHECK-NEXT:   37       AIV       0        A2/A3
# CHECK-NEXT:   38       AIV       0        A2/A3
# CHECK-NEXT:   39       AIV       0        A2/A3
# CHECK-NEXT:   40       AIV       0        A2/A3
# CHECK-NEXT:   45       AIV       0        A2/A3
# CHECK-NEXT:   46       AIV       0        A2/A3
# CHECK-NEXT:   47       AIV       0        A2/A3
# CHECK-EMPTY:
# CHECK:  Id           DataType                   MemType                     Addr                       Size             CoreId          dim
# CHECK-NEXT:   0    DEVICE_KERNEL_OBJECT                GM                   0x12c0c002e000                 182944             NA              NA
# CHECK-NEXT:   1            STACK                    GM/DCACHE           0xff000120000(invalid)              32768             36              NA
# CHECK-NEXT:   2            STACK                    GM/DCACHE           0xff000128000(invalid)              32768             37              NA
# CHECK-NEXT:   3            STACK                    GM/DCACHE           0xff000130000(invalid)              32768             38              NA
# CHECK-NEXT:   4            STACK                    GM/DCACHE           0xff000138000(invalid)              32768             39              NA
# CHECK-NEXT:   5            STACK                    GM/DCACHE           0xff000140000(invalid)              32768             40              NA
# CHECK-NEXT:   6            STACK                    GM/DCACHE           0xff000168000(invalid)              32768             45              NA
# CHECK-NEXT:   7            STACK                    GM/DCACHE           0xff000170000(invalid)              32768             46              NA
# CHECK-NEXT:   8            STACK                    GM/DCACHE           0xff000178000(invalid)              32768             47              NA
# CHECK-NEXT:   9      WORKSPACE_TENSOR                  GM                         0x0                         0               NA              NA
# CHECK-NEXT:  10         TILING_DATA                 GM/DCACHE               0x12c100240038                   16               NA              NA
# CHECK-NEXT:  11        OUTPUT_TENSOR                   GM                   0x12c0c0024000                  32768             NA              [8, 2048]
# CHECK-NEXT:  12        INPUT_TENSOR                    GM                   0x12c0c0012000                  32768             NA              [8, 2048]
# CHECK-NEXT:  13        INPUT_TENSOR                    GM                   0x12c0c001b000                  32768             NA              [8, 2048]
# CHECK-NEXT:  14            ARGS                     GM/DCACHE               0x12c100240000                   96               NA              NA

register read -a
# CHECK-LABEL: register read -a
# CHECK:Registers:
# CHECK-NEXT:                  GPR0 = 0x00000012c0c00120
# CHECK-NEXT:                  GPR1 = 0x0000000000000000
# CHECK-NEXT:                  GPR2 = 0x0000000000000800
# CHECK-NEXT:                  GPR3 = 0x0000000000000000
# CHECK-NEXT:                  GPR4 = 0x000000000000000f
# CHECK-NEXT:                  GPR5 = 0x0000000000000000
# CHECK-NEXT:                  GPR6 = 0x0000000000000100
# CHECK-NEXT:                  GPR7 = 0x00000000000004c9
# CHECK-NEXT:                  GPR8 = 0x0000000000000000
# CHECK-NEXT:                  GPR9 = 0x0000000000000000
# CHECK-NEXT:                 GPR10 = 0x00000000000004c9
# CHECK-NEXT:                 GPR11 = 0x000000000000001f
# CHECK-NEXT:                 GPR12 = 0x0001000808080101
# CHECK-NEXT:                 GPR13 = 0x0000000000000000
