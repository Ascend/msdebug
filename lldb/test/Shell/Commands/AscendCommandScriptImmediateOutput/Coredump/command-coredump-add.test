# CHECK-NEXT:                 VARF5 = 0x0000000000000000
# CHECK-NEXT:                 VARF6 = 0x0000000000000000
# CHECK-NEXT:                 VARF7 = 0x0000000000000000
# CHECK-NEXT:3 registers were unavailable.

register read PC
# CHECK-LABEL:register read PC
# CHECK:                  PC = 0x00000012c0c002fa

x -m GM -f uint8_t 0x12c0c002e000 -s 8 -c 1
# CHECK-LABEL:x -m GM -f uint8_t 0x12c0c002e000 -s 8 -c 1
# CHECK: 0x12c0c002e000: {0x01 0x00 0x00 0x07 0x80 0x00 0x00 0x02}

x -m GM -f uint8_t 0x12c100240038 -s 8 -c 1
# CHECK-LABEL:x -m GM -f uint8_t 0x12c100240038 -s 8 -c 1
# CHECK:0x12c100240038: {0x00 0x40 0x00 0x00 0x08 0x00 0x00 0x00}

x -m DCACHE -f uint8_t 0x12c100240038 -s 8 -c 1
# CHECK-LABEL:x -m DCACHE -f uint8_t 0x12c100240038 -s 8 -c 1
# CHECK:0x12c100240038: {0x00 0x40 0x00 0x00 0x08 0x00 0x00 0x00}

x -m GM -f uint8_t 0x12c100240038 -s 32 -c 2
# CHECK-LABEL:x -m GM -f uint8_t 0x12c100240038 -s 32 -c 2
# CHECK:0x12c100240038: {0x00 0x40 0x00 0x00 0x08 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0xa5 0xa5 0xa5 0xa5 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00}
# CHECK-NEXT:0x12c100240058: {0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00 0x00}

ascend aiv 37
# CHECK-LABEL:ascend aiv 37
# CHECK:[Switching to focus on CoreId 37, Type aiv]

x -m GM -f uint8_t 0xff000120000 -s 8 -c 1
# CHECK-LABEL:x -m GM -f uint8_t 0xff000120000 -s 8 -c 1
# CHECK-ERROR:error: this memory data is invalid, please check command: ascend info summary

x -m GM -f uint8_t 0x0 -s 8 -c 1
# CHECK-ERROR:error: addr is not in range, please check command: ascend info summary

ascend aiv 20
# CHECK-ERROR:Failed to switch focus to AIV 20

quit
