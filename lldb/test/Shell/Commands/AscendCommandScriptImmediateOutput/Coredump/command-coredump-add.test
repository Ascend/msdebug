# CHECK-NEXT:       VEC_EVENT_TABLE = 0x0000000000000000
# CHECK-NEXT:    SCALAR_EVENT_TABLE = 0x0000000000000000
# CHECK-NEXT:      MTE2_EVENT_TABLE = 0x0000000000000000
