# CHECK-NEXT:               CMPMASK = 0x000000000000008f
# CHECK-NEXT:              DEQSCALE = 0x0000000000000000
# CHECK-NEXT:            RPN_COR_IR = 0x0000000000000000
# CHECK-NEXT:               VMS4_SR = 0x0000000000000000
# CHECK-NEXT:             DATA_EXP0 = 0x0000000000000000
# CHECK-NEXT:             DATA_EXP1 = 0x0000000000000000
# CHECK-NEXT:             DATA_EXP2 = 0x0000000000000000
# CHECK-NEXT:             DATA_EXP3 = 0x0000000000000000
# CHECK-NEXT:            RPN_OFFSET = 0x0000003f8000003c
# CHECK-NEXT:              RSVD_CNT = 0x0000000000000000
